<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>env0 Demo — App Server</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      background: #000000;
      color: #ffffff;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    .card {
      text-align: center;
      background: #222423;
      border: 1px solid #383A39;
      border-radius: 16px;
      padding: 64px 80px;
      max-width: 540px;
      width: 90%;
    }
    .badge {
      display: inline-block;
      background: #B8E500;
      color: #000000;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 100px;
      margin-bottom: 28px;
    }
    h1 {
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: 24px;
    }
    h1 span { color: #B8E500; }
    .divider {
      border: none;
      border-top: 1px solid #383A39;
      margin: 28px 0;
    }
    .meta {
      display: flex;
      flex-direction: column;
      gap: 10px;
      text-align: left;
    }
    .meta-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.875rem;
    }
    .meta-label { color: #6b7280; }
    .meta-value {
      font-family: 'Menlo', 'Monaco', monospace;
      background: #383A39;
      padding: 2px 10px;
      border-radius: 6px;
      font-size: 0.8rem;
    }
    .stack {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 28px;
    }
    .pill {
      background: #383A39;
      color: #ffffff;
      font-size: 0.78rem;
      padding: 5px 14px;
      border-radius: 100px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="badge">App Tier</div>
    <h1>Powered by <span>env0</span></h1>
    <hr class="divider" />
    <div class="meta">
      <div class="meta-row">
        <span class="meta-label">Hostname</span>
        <span class="meta-value">{{ ansible_hostname }}</span>
      </div>
      <div class="meta-row">
        <span class="meta-label">Private IP</span>
        <span class="meta-value">{{ ansible_default_ipv4.address }}</span>
      </div>
      <div class="meta-row">
        <span class="meta-label">Role</span>
        <span class="meta-value">app</span>
      </div>
    </div>
    <div class="stack">
      <span class="pill">Terraform</span>
      <span class="pill">Ansible</span>
      <span class="pill">AWS EC2</span>
    </div>
  </div>
</body>
</html>
